{
  "name": "forge-coder",
  "version": "0.2.0",
  "description": "Forge CLI recovered from a public Claude Code snapshot and adapted into a runnable terminal coding assistant.",
  "private": false,
  "license": "UNLICENSED",
  "type": "module",
  "packageManager": "bun@1.3.0",
  "bin": {
    "forge": "bin/forge.js"
  },
  "files": [
    "README.md",
    "docs/usage.md",
    "docs/openai-oauth-smoke-test.md",
    "docs/recovery-roadmap.md",
    "bin",
    "generated",
    "scripts",
    "src",
    "tsconfig.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/General-zzz-trade/forge.git"
  },
  "homepage": "https://github.com/General-zzz-trade/forge",
  "bugs": {
    "url": "https://github.com/General-zzz-trade/forge/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepack": "bash -lc '\"${BUN_BIN:-$HOME/.bun/bin/bun}\" run generate'",
    "generate:sdk": "bash -lc '\"${BUN_BIN:-$HOME/.bun/bin/bun}\" run scripts/generate-sdk-types.ts'",
    "generate:settings-schema": "bash -lc '\"${BUN_BIN:-$HOME/.bun/bin/bun}\" run scripts/generate-settings-schema.ts'",
    "generate": "bash -lc '\"${BUN_BIN:-$HOME/.bun/bin/bun}\" run scripts/generate-sdk-types.ts && \"${BUN_BIN:-$HOME/.bun/bin/bun}\" run scripts/generate-settings-schema.ts'",
    "dev": "bash -lc '\"${BUN_BIN:-$HOME/.bun/bin/bun}\" run generate' && bash scripts/run-forge-cli.sh",
    "start": "bash -lc '\"${BUN_BIN:-$HOME/.bun/bin/bun}\" run generate' && bash scripts/run-forge-cli.sh",
    "cli": "bash -lc '\"${BUN_BIN:-$HOME/.bun/bin/bun}\" run generate' && bash scripts/run-forge-cli.sh",
    "version": "bash scripts/run-forge-cli.sh --version",
    "recovery:audit": "node scripts/recovery-audit.mjs",
    "preflight:openai": "node scripts/openai-oauth-preflight.mjs",
    "mock:gateway": "node scripts/mock-forge-gateway.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.81.0",
    "@commander-js/extra-typings": "^14.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.214.0",
    "@opentelemetry/core": "^2.6.1",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-logs": "^0.214.0",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "axios": "^1.14.0",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "cli-boxes": "^4.0.1",
    "commander": "^14.0.3",
    "diff": "^8.0.4",
    "bun": "^1.3.11",
    "emoji-regex": "^10.6.0",
    "env-paths": "^4.0.0",
    "execa": "^9.6.1",
    "figures": "^6.1.0",
    "fuse.js": "^7.1.0",
    "google-auth-library": "^10.6.2",
    "highlight.js": "^11.11.1",
    "https-proxy-agent": "^9.0.0",
    "ignore": "^7.0.5",
    "ink": "^6.8.0",
    "jsonc-parser": "^3.3.1",
    "lodash-es": "^4.17.23",
    "lru-cache": "^11.2.7",
    "marked": "^17.0.5",
    "p-map": "^7.0.4",
    "proper-lockfile": "^4.1.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-reconciler": "^0.33.0",
    "semver": "^7.7.4",
    "shell-quote": "^1.8.3",
    "strip-ansi": "^7.2.0",
    "supports-hyperlinks": "^4.4.0",
    "undici": "^7.24.7",
    "usehooks-ts": "^3.1.1",
    "wrap-ansi": "^10.0.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  }
}
