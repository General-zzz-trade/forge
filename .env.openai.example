# Optional browser-based OpenAI OAuth client configuration.
# If Codex CLI is already logged in (`codex login`), Forge can reuse that state
# and these can stay unset.
FORGE_OPENAI_CLIENT_ID=replace-with-your-openai-client-id
FORGE_OPENAI_CLIENT_SECRET=replace-with-your-openai-client-secret
FORGE_OPENAI_REDIRECT_URI=http://localhost:1455/callback
FORGE_OPENAI_SCOPES="openid profile email offline_access"

# Optional legacy bridge endpoints for local smoke tests.
# Leave these unset for direct Codex CLI / browser OAuth login.
# Uncomment them if you still want to validate broker/bootstrap compatibility.
# FORGE_AUTH_BROKER_URL=http://127.0.0.1:8787
# FORGE_AUTH_BROKER_EXCHANGE_PATH=/oauth/exchange
# FORGE_API_BASE_URL=http://127.0.0.1:8787

# Optional defaults for the login UI/CLI
FORGE_AUTH_PROVIDER=openai

# Optional OpenAI overrides
# FORGE_OPENAI_ISSUER=https://auth.openai.com
# FORGE_OPENAI_AUTHORIZATION_ENDPOINT=https://auth.openai.com/authorize
# FORGE_OPENAI_TOKEN_ENDPOINT=https://auth0.openai.com/oauth/token
# FORGE_OPENAI_USERINFO_ENDPOINT=https://auth0.openai.com/userinfo
# FORGE_OPENAI_AUDIENCE=

# Optional broker audience hint
# FORGE_AUTH_BROKER_AUDIENCE=
